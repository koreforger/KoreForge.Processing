<Project>
  <PropertyGroup>
    <Product>KoreForge.Processing</Product>
    <Company>KoreForge</Company>
    <Authors>KoreForge</Authors>
    <Copyright>Copyright © KoreForge</Copyright>
    <PackageOutputPath>$(MSBuildThisFileDirectory)artifacts\</PackageOutputPath>
    <PackageProjectUrl>https://github.com/koreforger/KoreForge.Processing</PackageProjectUrl>
    <RepositoryUrl>https://github.com/koreforger/KoreForge.Processing</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <MinVerTagPrefix>KoreForge.Processing/v</MinVerTagPrefix>
    <MinVerAutoIncrement>minor</MinVerAutoIncrement>
    <MinVerDefaultPreReleaseIdentifiers>alpha.0</MinVerDefaultPreReleaseIdentifiers>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1570;CS1571;CS1572;CS1573;CS1574;CS1580;CS1581;CS1584;CS1587;CS1589;CS1590;CS1591;CS1592;CS1593;CS1594;CS1595;CS1596;CS1597;CS1598;CS1599</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MinVer" PrivateAssets="all" />
  </ItemGroup>

  <Target Name="ApplyMinVerVersion"
          DependsOnTargets="MinVer"
          BeforeTargets="GetAssemblyVersion">
    <PropertyGroup Condition="'$(IsPackable)' != 'false'">
      <Version Condition="'$(Version)' == ''">$(MinVerVersion)</Version>
      <PackageVersion Condition="'$(PackageVersion)' == ''">$(MinVerVersion)</PackageVersion>
      <AssemblyVersion Condition="'$(AssemblyVersion)' == ''">$(MinVerMajor).$(MinVerMinor).0.0</AssemblyVersion>
      <FileVersion Condition="'$(FileVersion)' == ''">$(MinVerMajor).$(MinVerMinor).$(MinVerPatch).0</FileVersion>
    </PropertyGroup>
  </Target>
</Project>
